# ─── NameNest .env ──────────────────────────────────
# Required by the Expo client to find the local API server.
EXPO_PUBLIC_DOMAIN=localhost:5000

# AI name generation (uses Z.ai OpenAI-compatible endpoint by default).
# Leave blank to fall back to static name lists (no AI).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4
OPENAI_MODEL=glm-4.7-flash

# Only needed if you run `npm run db:push` (not required for local dev).
# The app uses in-memory storage, so this can stay blank.
DATABASE_URL=
